<!DOCTYPE html>
<html>
<head>
  <title>Products</title>

  <style>
    body {
      background-color: #bfbfbf;
      font-family: Arial;
      text-align: center;
      margin: 0;
    }

    .top {
      display: flex;
      justify-content: space-between;
      padding: 20px;
    }

    .btn {
      padding: 10px 20px;
      border: 2px solid green;
      border-radius: 8px;
      text-decoration: none;
      color: black;
      background: white;
    }

    .header {
      background-color: #4f75b5;
      color: white;
      padding: 10px;
      width: 250px;
      margin: 20px auto;
      border-radius: 5px;
      font-size: 18px;
    }

    .container {
      display: flex;
      justify-content: center;
      gap: 40px;
      flex-wrap: wrap;
      margin-top: 40px;
    }

    .card {
      background-color: #4f75b5;
      color: white;
      padding: 20px;
      border-radius: 20px;
      width: 180px;
      box-shadow: 2px 2px 10px rgba(0,0,0,0.3);
    }

    .card img {
      width: 100px;
      height: 100px;
      border-radius: 10px;
      object-fit: cover;
    }

    .card button {
      margin-top: 10px;
      padding: 8px 12px;
      border-radius: 5px;
      border: none;
      cursor: pointer;
    }

  </style>
</head>

<body>

<!-- 🔝 TOP NAV -->
<div class="top">
  <a href="/user" class="btn">Home</a>
  <a href="/cart" class="btn">Cart</a>
  <a href="/logout" class="btn">LogOut</a>
</div>

<!-- 🔵 VENDOR NAME -->
<div class="header">
  <%= vendor.username %>
</div>

<!-- 🛒 PRODUCTS -->
<div class="container">

  <% if(products.length === 0){ %>
    <h3>No products available ❌</h3>
  <% } %>

  <% products.forEach(p => { %>

    <div class="card">

      <!-- IMAGE -->
      <img src="<%= p.image %>" alt="product">

      <!-- NAME -->
      <h3><%= p.name %></h3>

      <!-- PRICE -->
      <p>₹ <%= p.price %></p>

      <!-- ADD TO CART -->
      <form action="/cart/add/<%= p._id %>" method="POST">
        <button>Add to Cart</button>
      </form>

    </div>

  <% }) %>

</div>

</body>
</html>