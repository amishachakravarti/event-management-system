<!DOCTYPE html>
<html>
<head>
  <title>Maintain Users</title>

  <style>
    body { background:#bfbfbf; font-family:Arial; text-align:center; }
    .row { display:flex; justify-content:center; gap:20px; margin:10px; }
    .box { background:#4f75b5; color:white; padding:10px; width:150px; border-radius:8px; }
    .btn { padding:5px 10px; border:none; border-radius:5px; cursor:pointer; }
  </style>
</head>

<body>

<h2>All Users</h2>

<% users.forEach(u => { %>

  <div class="row">
    <div class="box"><%= u.username %></div>
    <div class="box"><%= u.role %></div>

    <!-- DELETE -->
    <form action="/admin/user/delete/<%= u._id %>" method="POST">
      <button class="btn">Delete</button>
    </form>

    <!-- UPDATE ROLE -->
    <form action="/admin/user/update/<%= u._id %>" method="POST">
      <select name="role">
        <option value="user">User</option>
        <option value="vendor">Vendor</option>
        <option value="admin">Admin</option>
      </select>
      <button class="btn">Update</button>
    </form>
  </div>

<% }) %>

</body>
</html>