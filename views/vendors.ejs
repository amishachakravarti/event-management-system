<!DOCTYPE html>
<html>
<head>
  <title>Vendors</title>

  <style>
    body { background:#bfbfbf; font-family:Arial; text-align:center; }

    .top { display:flex; justify-content:space-between; padding:20px; }

    .btn { padding:10px 20px; border:2px solid green; border-radius:5px; }

    .header {
      background:#4f75b5;
      color:white;
      padding:10px;
      width:300px;
      margin:0 auto;
      border-radius:5px;
    }

    .container {
      display:flex;
      justify-content:center;
      gap:40px;
      margin-top:40px;
    }

    .card {
      background:#4f75b5;
      color:white;
      padding:30px;
      border-radius:20px;
      width:150px;
    }

    .card button {
      margin-top:10px;
      padding:5px 10px;
    }
  </style>
</head>

<body>

<div class="top">
  <a href="/user" class="btn">Home</a>
  <a href="/logout" class="btn">LogOut</a>
</div>

<div class="header">Vendor - Florist</div>

<div class="container">

  <% vendors.forEach(v => { %>
    <div class="card">
      <h3><%= v.username %></h3>
      <p>Contact Details</p>

      <a href="/vendors/<%= v._id %>">
        <button>Shop Item</button>
      </a>
    </div>
  <% }) %>

</div>

</body>
</html>