<!DOCTYPE html>
<html>
<head>
  <title>Home</title>

  <style>
    body {
      background-color: #4f75b5;
      font-family: Arial, sans-serif;
      text-align: center;
      margin: 0;
      padding: 0;
    }

    .header {
      background-color: #d3d3d3;
      padding: 20px;
      margin: 30px auto;
      width: 70%;
      font-size: 22px;
      font-weight: bold;
      border-radius: 5px;
    }

    .container {
      margin-top: 60px;
    }

    .btn-container {
      display: flex;
      justify-content: center;
      gap: 40px;
    }

    .btn {
      background-color: #d3d3d3;
      padding: 15px 35px;
      border-radius: 10px;
      text-decoration: none;
      color: black;
      font-size: 16px;
      font-weight: bold;
      box-shadow: 2px 2px 5px rgba(0,0,0,0.3);
    }

    .btn:hover {
      background-color: #c0c0c0;
    }
  </style>

</head>

<body>

  <div class="header">
    Event Management System
  </div>

  <div class="container">
    <h2>Welcome 🎉</h2>

    <div class="btn-container">
      <a href="/login" class="btn">Login</a>
      <a href="/register" class="btn">Register</a>
    </div>
  </div>

</body>
</html>