<!DOCTYPE html>
<html>
<head>
  <title>Admin Dashboard</title>

  <style>
    body {
      background-color: #bfbfbf;
      font-family: Arial;
      margin: 0;
      text-align: center;
    }

    .top {
      display: flex;
      justify-content: space-between;
      padding: 20px;
    }

    .btn {
      padding: 10px 25px;
      border: 2px solid green;
      border-radius: 10px;
      background-color: white;
      text-decoration: none;
      color: black;
    }

    .header {
      background-color: #e5e5e5;
      padding: 15px;
      width: 400px;
      margin: 40px auto;
      border-radius: 10px;
      border: 2px solid green;
      font-size: 18px;
    }

    .container {
      display: flex;
      justify-content: space-around;
      margin-top: 100px;
    }

    .card {
      padding: 20px 40px;
      border: 2px solid green;
      border-radius: 10px;
      background-color: white;
      cursor: pointer;
    }

  </style>
</head>

<body>

<!-- TOP NAV -->
<div class="top">
  <a href="/" class="btn">Home</a>
  <a href="/logout" class="btn">LogOut</a>
</div>

<!-- HEADER -->
<div class="header">
  Welcome Admin
</div>

<!-- OPTIONS -->
<div class="container">

  <a href="/admin/users" class="card">
    Maintain User
  </a>

  <a href="/admin/orders" class="card">
    Maintain Order
  </a>

</div>

</body>
</html>