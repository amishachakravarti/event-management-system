<!DOCTYPE html>
<html>
<head>
  <title>Login</title>

  <style>
    body {
      background-color: #e2dfdf;
      font-family: Arial;
      text-align: center;
    }

    .header {
      background-color: #7da2d6;
      padding: 15px;
      margin: 20px auto;
      width: 80%;
      font-size: 20px;
      border-radius: 5px;
    }

    .container {
      margin-top: 50px;
    }

    .row {
      display: flex;
      justify-content: center;
      margin: 20px;
      gap: 20px;
    }

    .label {
      background-color: #4f75b5;
      padding: 10px;
      width: 120px;
      border-radius: 8px;
      color: white;
    }

    .input {
      padding: 10px;
      width: 250px;
      background-color: #7da2d6;
      border: none;
      border-radius: 5px;
    }

    .btn {
      padding: 10px 30px;
      margin: 20px;
      border-radius: 10px;
      border: 1px solid black;
      background-color: #d9d9d9;
      cursor: pointer;
    }
  </style>
</head>

<body>

  <div class="header">Event Management System</div>

  <form action="/login" method="POST" class="container">

    <div class="row">
      <div class="label">User Id</div>
      <input type="text" name="username" class="input" required>
    </div>

    <div class="row">
      <div class="label">Password</div>
      <input type="password" name="password" class="input" required>
    </div>

    <div>
      <button type="reset" class="btn">Cancel</button>
      <button type="submit" class="btn">Login</button>
    </div>

  </form>

</body>
</html>